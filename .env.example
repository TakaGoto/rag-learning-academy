# RAG Learning Academy — Environment Variables
# Copy this to .env and fill in your keys

# LLM Provider (pick one or both)
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# Embedding Models
# Used for OpenAI embeddings (text-embedding-3-small)
# OPENAI_API_KEY is shared above

# Vector Database (optional — ChromaDB works locally without keys)
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_ENVIRONMENT=your-pinecone-env

# Cohere (optional — for reranking)
COHERE_API_KEY=your-cohere-key-here

# Evaluation
# No additional keys needed for RAGAS (uses your LLM provider keys)

# Qdrant (optional — for Module 04 lessons)
# QDRANT_URL=http://localhost:6333

# Weaviate (optional — for Module 04 lessons)
# WEAVIATE_URL=http://localhost:8080
